OPENAI_API_KEY=
OPENAI_BASE_URL=https://ai.exit0.link/v1
OPENAI_MODEL=gpt-5.3-codex-spark
OPENAI_MAX_OUTPUT_TOKENS=1000
OPENAI_PROVIDER_MODE=responses
OPENAI_REASONING_EFFORT=low
